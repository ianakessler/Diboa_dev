### 4.3 Criar o serviço Shopify

Crie o arquivo `src/services/shopifyService.js`:

```js
// src/services/shopifyService.js
import logger from '../config/logger.js';

const SHOPIFY_DOMAIN  = process.env.SHOPIFY_STORE_DOMAIN;
const ACCESS_TOKEN    = process.env.SHOPIFY_ADMIN_ACCESS_TOKEN;
const API_VERSION     = process.env.SHOPIFY_API_VERSION || '2025-01';

const BASE_URL = `https://${SHOPIFY_DOMAIN}/admin/api/${API_VERSION}`;

/**
 * Cria um cupom de desconto fixo no Shopify.
 *
 * Fluxo: cria uma Price Rule → cria um Discount Code vinculado a ela.
 *
 * @param {object} params
 * @param {string} params.codigo   - Código do cupom (ex: "DIBOA-A3F8K2")
 * @param {number} params.valor    - Valor do desconto em R$ (ex: 7.00)
 * @param {string} params.titulo   - Título legível (ex: "Cashback de R$ 7")
 * @returns {Promise<{ codigo: string, priceRuleId: number }>}
 */
export async function criarCupomDesconto({ codigo, valor, titulo }) {
  // ── 1. Criar Price Rule ────────────────────────────────────
  const agora = new Date().toISOString();
  const expira = new Date(Date.now() + 30 * 24 * 60 * 60 * 1000).toISOString(); // 30 dias

  const priceRuleBody = {
    price_rule: {
      title: titulo,
      target_type: 'line_item',            // desconto aplicado nos itens
      target_selection: 'all',             // todos os produtos
      allocation_method: 'across',         // distribui entre os itens
      value_type: 'fixed_amount',          // valor fixo em R$
      value: `-${valor.toFixed(2)}`,       // Shopify espera negativo
      customer_selection: 'all',           // qualquer cliente pode usar
      usage_limit: 1,                      // uso único
      once_per_customer: true,
      starts_at: agora,
      ends_at: expira,
    },
  };

  const priceRuleRes = await fetch(`${BASE_URL}/price_rules.json`, {
    method: 'POST',
    headers: {
      'Content-Type': 'application/json',
      'X-Shopify-Access-Token': ACCESS_TOKEN,
    },
    body: JSON.stringify(priceRuleBody),
  });

  if (!priceRuleRes.ok) {
    const err = await priceRuleRes.text();
    logger.error('Shopify: erro ao criar price rule', { status: priceRuleRes.status, body: err });
    throw new Error(`Falha ao criar regra de desconto no Shopify: ${priceRuleRes.status}`);
  }

  const { price_rule } = await priceRuleRes.json();
  logger.info('Shopify: price rule criada', { id: price_rule.id, titulo });

  // ── 2. Criar Discount Code vinculado ──────────────────────
  const discountBody = {
    discount_code: {
      code: codigo,
    },
  };

  const discountRes = await fetch(
    `${BASE_URL}/price_rules/${price_rule.id}/discount_codes.json`,
    {
      method: 'POST',
      headers: {
        'Content-Type': 'application/json',
        'X-Shopify-Access-Token': ACCESS_TOKEN,
      },
      body: JSON.stringify(discountBody),
    }
  );

  if (!discountRes.ok) {
    const err = await discountRes.text();
    logger.error('Shopify: erro ao criar discount code', { status: discountRes.status, body: err });
    throw new Error(`Falha ao criar código de desconto no Shopify: ${discountRes.status}`);
  }

  const { discount_code } = await discountRes.json();
  logger.info('Shopify: cupom criado', { code: discount_code.code, priceRuleId: price_rule.id });

  return {
    codigo: discount_code.code,
    priceRuleId: price_rule.id,
  };
}
```

### 4.4 Criar o serviço de resgate para o storefront

Crie o arquivo `src/services/storefrontResgateService.js`:

```js
// src/services/storefrontResgateService.js
import crypto from 'node:crypto';
import pool from '../config/db.js';
import * as clienteRepo from '../repository/clienteRepository.js';
import { validateCpf } from '../validators/index.js';
import { NotFoundError, InsufficientBalanceError, BadRequestError } from '../errors/AppError.js';
import { criarCupomDesconto } from './shopifyService.js';
import PREMIOS from '../config/premios.js';
import logger from '../config/logger.js';

/**
 * Consulta pontos e prêmios disponíveis para um CPF.
 */
export async function consultarPontos(rawCpf) {
  const cpf = validateCpf(rawCpf);
  const cliente = await clienteRepo.findByCpf(cpf);
  if (!cliente) throw new NotFoundError('CPF não encontrado no programa de cashback');

  const pontosDisponiveis = Number(cliente.pontos);

  const premiosDisponiveis = PREMIOS
    .filter(p => pontosDisponiveis >= p.pontos)
    .map(p => ({
      id: p.id,
      titulo: p.titulo,
      pontos: p.pontos,
      valor: p.valor,
    }));

  return {
    nome: cliente.nome.split(' ')[0],        // só o primeiro nome (privacidade)
    pontos: pontosDisponiveis,
    premios: premiosDisponiveis,
    totalPremios: PREMIOS.length,
  };
}

/**
 * Resgata um prêmio: deduz pontos + cria cupom no Shopify.
 */
export async function resgatarPremio(rawCpf, premioId) {
  const cpf = validateCpf(rawCpf);

  // Validar prêmio
  const premio = PREMIOS.find(p => p.id === premioId);
  if (!premio) throw new BadRequestError('Prêmio inválido');

  // Gerar código único para o cupom
  const sufixo = crypto.randomBytes(4).toString('hex').toUpperCase();
  const codigoCupom = `DIBOA-${sufixo}`;

  // Transação: verificar saldo → deduzir pontos → registrar resgate
  const conn = await pool.getConnection();
  try {
    await conn.beginTransaction();

    const cliente = await clienteRepo.findByCpfForUpdate(conn, cpf);
    if (!cliente) throw new NotFoundError('CPF não encontrado');
    if (cliente.pontos < premio.pontos) {
      throw new InsufficientBalanceError(
        `Saldo insuficiente. Disponível: ${cliente.pontos}, necessário: ${premio.pontos}`
      );
    }

    // Deduzir pontos
    await clienteRepo.deductPontos(conn, cliente.id, premio.pontos);

    // Registrar no histórico
    await clienteRepo.insertResgate(conn, cliente.client_id, premio.pontos);

    // Criar cupom no Shopify (fora da transação do banco seria ideal,
    // mas para simplicidade, fazemos aqui e revertemos se falhar)
    let cupom;
    try {
      cupom = await criarCupomDesconto({
        codigo: codigoCupom,
        valor: premio.valor,
        titulo: `${premio.titulo} — Resgate cashback`,
      });
    } catch (shopifyErr) {
      logger.error('Erro ao criar cupom no Shopify, revertendo transação', {
        error: shopifyErr.message,
      });
      throw shopifyErr; // vai cair no rollback
    }

    await conn.commit();

    logger.info('Resgate storefront concluído', {
      cpf: cpf.slice(0, 3) + '***',
      premioId,
      cupom: cupom.codigo,
    });

    return {
      cupom: cupom.codigo,
      valor: premio.valor,
      mensagem: `Use o cupom ${cupom.codigo} na finalização da compra. Validade: 30 dias.`,
    };
  } catch (error) {
    await conn.rollback();
    throw error;
  } finally {
    conn.release();
  }
}
```

### 4.5 Criar o controller do storefront

Crie o arquivo `src/controllers/storefrontController.js`:

```js
// src/controllers/storefrontController.js
import * as storefrontService from '../services/storefrontResgateService.js';

export async function consultarCpf(req, res, next) {
  try {
    const resultado = await storefrontService.consultarPontos(req.params.cpf);
    return res.status(200).json(resultado);
  } catch (error) {
    next(error);
  }
}

export async function resgatarPremio(req, res, next) {
  try {
    const { cpf, premioId } = req.body;
    const resultado = await storefrontService.resgatarPremio(cpf, premioId);
    return res.status(200).json(resultado);
  } catch (error) {
    next(error);
  }
}
```

### 4.6 Criar as rotas do storefront

Crie o arquivo `src/routes/storefrontRoutes.js`:

```js
// src/routes/storefrontRoutes.js
import { Router } from 'express';
import rateLimit from 'express-rate-limit';
import { consultarCpf, resgatarPremio } from '../controllers/storefrontController.js';

const router = Router();

// Rate limit mais restrito para rotas públicas do storefront
const storefrontLimiter = rateLimit({
  windowMs: 15 * 60 * 1000,   // 15 min
  max: 30,                      // 30 requisições por IP
  message: { error: { code: 'RATE_LIMIT', message: 'Muitas tentativas. Aguarde alguns minutos.' } },
});

router.use(storefrontLimiter);

router.get('/storefront/consulta/:cpf', consultarCpf);
router.post('/storefront/resgatar', resgatarPremio);

export default router;
```

