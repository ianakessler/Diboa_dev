    painel.style.transform = painelAberto ? 'translateX(0)' : 'translateX(-100%)';
    overlay.style.display = painelAberto ? 'block' : 'none';
  };

  // ── Formatar CPF ─────────────────────────────────────
  window.diboaFormatarCpf = function(el) {
    let v = el.value.replace(/\D/g, '');
    if (v.length > 11) v = v.slice(0, 11);
    if (v.length > 9) v = v.slice(0,3) + '.' + v.slice(3,6) + '.' + v.slice(6,9) + '-' + v.slice(9);
    else if (v.length > 6) v = v.slice(0,3) + '.' + v.slice(3,6) + '.' + v.slice(6);
    else if (v.length > 3) v = v.slice(0,3) + '.' + v.slice(3);
    el.value = v;
  };

  // ── Consultar CPF ────────────────────────────────────
  window.diboaConsultar = async function() {
    const input = document.getElementById('diboa-cpf-input');
    const resultado = document.getElementById('diboa-resultado');
    const cpf = input.value.replace(/\D/g, '');

    if (cpf.length !== 11) {
      resultado.innerHTML = '<p style="color:red;font-size:14px;">CPF inválido. Digite 11 dígitos.</p>';
      return;
    }

    cpfAtual = cpf;
    resultado.innerHTML = '<p style="color:#666;font-size:14px;">Consultando...</p>';

    try {
      const res = await fetch(`${API_URL}/api/v1/storefront/consulta/${cpf}`);
      const data = await res.json();

      if (!res.ok) {
        resultado.innerHTML = `<p style="color:red;font-size:14px;">${data.error?.message || 'CPF não encontrado.'}</p>`;
        return;
      }

      let html = `
        <div style="background:#f8f8f8;border-radius:8px;padding:14px;margin-bottom:16px;">
          <p style="margin:0;font-size:15px;">Olá, <strong>${data.nome}</strong>!</p>
          <p style="margin:6px 0 0;font-size:22px;font-weight:700;color:#333;">
            ${data.pontos} <span style="font-size:13px;color:#666;">pontos</span>
          </p>
        </div>
        <h3 style="margin:0 0 12px;font-size:16px;">Prêmios <span style="font-weight:400;font-size:13px;color:#999;">total de ${data.totalPremios} prêmios</span></h3>
      `;

      if (data.premios.length === 0) {
        html += '<p style="font-size:14px;color:#999;">Nenhum prêmio disponível para seu saldo atual.</p>';
      } else {
        data.premios.forEach(p => {
          html += `
            <div style="border:1px solid #e0e0e0;border-radius:8px;padding:14px;margin-bottom:10px;">
              <div style="display:flex;justify-content:space-between;align-items:center;">
                <div>
                  <p style="margin:0;font-size:14px;font-weight:600;">${p.titulo}</p>
                  <p style="margin:4px 0 0;font-size:14px;color:{{ cor_primaria }};font-weight:700;">${p.pontos} PONTOS</p>
                </div>
              </div>
              <div style="display:flex;gap:8px;margin-top:10px;">
                <button onclick="diboaResgatar(${p.id}, '${p.titulo}')" style="
                  flex:1;background:{{ cor_primaria }};color:#fff;border:none;border-radius:6px;
                  padding:10px;cursor:pointer;font-size:14px;font-weight:600;
                ">🎁 Resgatar</button>
              </div>
            </div>
          `;
        });
      }

      resultado.innerHTML = html;
    } catch (err) {
      resultado.innerHTML = '<p style="color:red;font-size:14px;">Erro de conexão. Tente novamente.</p>';
    }
  };

  // ── Resgatar Prêmio ──────────────────────────────────
  window.diboaResgatar = async function(premioId, titulo) {
    if (!confirm(`Deseja resgatar: ${titulo}?`)) return;

    const resultado = document.getElementById('diboa-resultado');
    resultado.innerHTML = '<p style="color:#666;font-size:14px;">Gerando seu cupom...</p>';

    try {
      const res = await fetch(`${API_URL}/api/v1/storefront/resgatar`, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ cpf: cpfAtual, premioId }),
      });
      const data = await res.json();

      if (!res.ok) {
        resultado.innerHTML = `<p style="color:red;font-size:14px;">${data.error?.message || 'Erro ao resgatar.'}</p>`;
        return;
      }

      resultado.innerHTML = `
        <div style="text-align:center;padding:20px 0;">
          <div style="font-size:48px;margin-bottom:10px;">🎉</div>
          <h3 style="margin:0 0 10px;color:#333;">Cupom gerado com sucesso!</h3>
          <div style="
            background:#f0faf0;border:2px dashed #2ecc71;border-radius:10px;
            padding:16px;margin:16px 0;
          ">
            <p style="margin:0 0 4px;font-size:12px;color:#999;">Seu código de desconto:</p>
            <p style="margin:0;font-size:24px;font-weight:800;color:#333;letter-spacing:2px;">${data.cupom}</p>
            <p style="margin:8px 0 0;font-size:14px;color:#666;">Desconto de R$ ${data.valor.toFixed(2)}</p>
          </div>
          <p style="font-size:13px;color:#666;">${data.mensagem}</p>
          <button onclick="navigator.clipboard.writeText('${data.cupom}');this.textContent='Copiado ✓'" style="
            margin-top:12px;background:#333;color:#fff;border:none;border-radius:6px;
            padding:10px 24px;cursor:pointer;font-size:14px;
          ">📋 Copiar cupom</button>
          <br/>
          <button onclick="diboaConsultar()" style="
            margin-top:10px;background:none;border:1px solid #ccc;border-radius:6px;
            padding:8px 20px;cursor:pointer;font-size:13px;color:#666;
          ">← Voltar aos prêmios</button>
        </div>
      `;
    } catch (err) {
      resultado.innerHTML = '<p style="color:red;font-size:14px;">Erro de conexão. Tente novamente.</p>';
    }
  };
})();
</script>

